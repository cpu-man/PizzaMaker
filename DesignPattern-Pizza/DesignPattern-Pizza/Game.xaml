<Window x:Class="DesignPattern_Pizza.Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesignPattern_Pizza"
        mc:Ignorable="d"
        Title="Pizzeria" 
        Icon="/Pizza Maker.game.logo.ico"
        WindowState="Maximized" 
        Background="#A2D9CE">

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">

            <Grid.RowDefinitions>
                <RowDefinition Height="350" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TOP HUD -->
            <Grid Grid.Row="0">

                <Rectangle VerticalAlignment="Bottom" Height="80" Fill="#E67E22" Stroke="#D35400" StrokeThickness="4" />

                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="350" />
                    </Grid.ColumnDefinitions>

                    <!-- Customer speech bubble -->
                    <StackPanel x:Name="CustomerOrderPanel" Margin="20" VerticalAlignment="Center">
                    </StackPanel>


                    <!-- Bubble tail -->
                    <Polygon Grid.Column="0"
                             Points="0,0 30,40 60,0" Fill="White"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="150,238,0,0" />

                    <!-- Earnings panel -->
                    <Border Grid.Column="1"
                            Background="#2C3E50" CornerRadius="15"
                            BorderBrush="#1ABC9C" BorderThickness="5"
                            Padding="20" Height="150" VerticalAlignment="Top"
                            Margin="0,20,20,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="💰 EARNINGS" FontSize="20" FontWeight="Bold" Foreground="#1ABC9C" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EarningsLabel"
                                       Text="DKK 0.00" FontSize="42" FontWeight="Bold" Foreground="#2ECC71" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>

            <!-- MAIN GAME AREA -->
            <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="450" />
                    </Grid.ColumnDefinitions>

                    <!-- Col 0: Topping buttons -->
                    <WrapPanel Grid.Column="0"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="20">

                        <Button x:Name="KebabButton" Width="130" Height="130" Margin="15"
                                Background="Brown" BorderBrush="#873600" BorderThickness="4"
                                Cursor="Hand" Click="Kebab_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Kebab" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="MozzaButton" Width="130" Height="130" Margin="15"
                                Background="AntiqueWhite" BorderBrush="#B7950B" BorderThickness="4"
                                Cursor="Hand" Click="Mozza_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Mozzarella" FontSize="22" FontWeight="Bold" Foreground="#7D6608" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="ParmaButton" Width="130" Height="130" Margin="15"
                                Background="#E74C3C" BorderBrush="#943126" BorderThickness="4"
                                Cursor="Hand" Click="Parma_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Parma" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="GorgonButton" Width="130" Height="130" Margin="15"
                                Background="#5DADE2" BorderBrush="#2874A6" BorderThickness="4"
                                Cursor="Hand" Click="Gorgon_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Gorgonzola" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="MenuButton" Width="130" Height="60" Margin="15,4,15,15"
                          Background="#E74C3C" BorderBrush="#C0392B" BorderThickness="3"
                          Cursor="Hand" Click="Menu_Click">
                            <TextBlock Text="🏠 MENU" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        </Button>

                    </WrapPanel>

                    <!-- Col 1: Base selector -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="10,0">

                        <TextBlock Text="Choose base:"
                                   FontSize="16" FontWeight="Bold" Foreground="#2C3E50"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <Button x:Name="BtnMargherita"
                                Width="130" Height="130" Margin="0,0,0,30"
                                Background="#C0392B" BorderBrush="#922B21" BorderThickness="4"
                                Cursor="Hand" Click="Margherita_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Margherita" FontSize="17" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnBianca"
                                Width="130" Height="130"
                                Background="#F8F9F9" BorderBrush="#AEB6BF" BorderThickness="4"
                                Cursor="Hand" Click="Bianca_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Bianca" FontSize="17" FontWeight="Bold" Foreground="#5D6D7E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!-- Col 2: Pizza canvas -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <Grid x:Name="PizzaCanvas" Width="500" Height="500">
                            <Ellipse Fill="#E67E22" Stroke="#BA4A00" StrokeThickness="10" />
                            <Ellipse Width="420" Height="420" Fill="#F5CBA7" Stroke="#E59866" StrokeThickness="8" />
                        </Grid>

                        <TextBlock x:Name="PizzaStatusBlock"
                                   Text="Your Pizza: Empty"
                                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"/>

                        <TextBlock x:Name="PriceStatusBlock"
                                   Text="Current Price: "
                                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>

                    </StackPanel>

                    <!-- Col 3: Oven -->
                    <Border Grid.Column="3"
                            Background="#34495E" CornerRadius="30"
                            Margin="20,40,40,40"
                            BorderBrush="#2C3E50" BorderThickness="10">
                        <StackPanel VerticalAlignment="Center" Margin="20">

                            <Border Background="#17202A" Height="250"
                                    CornerRadius="150,150,15,15"
                                    BorderBrush="#7F8C8D" BorderThickness="5"
                                    Margin="0,0,0,40">
                                <!-- Flames — start dark, turn red on bake -->
                                <TextBlock x:Name="FlameLabel"
                                           Text="🔥 🔥 🔥" FontSize="48"
                                           Foreground="#333333"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>
                            </Border>

                            <Button x:Name="BakeButton"
                                    Content="BAKE PIZZA"
                                    FontSize="32" FontWeight="Bold" Height="80"
                                    Background="#27AE60" Foreground="White"
                                    BorderThickness="4" BorderBrush="#1E8449"
                                    Cursor="Hand" Click="Bake_Click"/>

                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Viewbox>
</Window>