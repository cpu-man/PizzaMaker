     <!-- 
     PIZZERIA GAME - Main Window (DesignPattern_Pizza)
     Style: Zygomatic
     Layout: 1920x1080, split into TOP BAR (350px) and MAIN AREA (*)
     -->
<Window x:Class="DesignPattern_Pizza.Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesignPattern_Pizza"
        mc:Ignorable="d"
        Title="Pizzeria - Zygomatic Style" 
        WindowState="Maximized" 
        Background="#A2D9CE">
    <!-- Mint background for the whole window -->

    <!-- Viewbox scales all content uniformly to fit the window size -->
    <Viewbox Stretch="Uniform">

        <!-- Root 1920x1080 canvas split into two rows:
             Row 0 = Top HUD bar (350px tall)
             Row 1 = Main gameplay area (remaining height) -->
        <Grid Width="1920" Height="1080">

            <Grid.RowDefinitions>
                <RowDefinition Height="350" />
                <!-- Row 0: Top HUD -->
                <RowDefinition Height="*" />
                <!-- Row 1: Game area -->
            </Grid.RowDefinitions>

            <!-- 
                 ROW 0 — TOP HUD BAR
                 Contains: Customer order speech bubble + Earnings counter -->
            <Grid Grid.Row="0">

                <!-- Orange decorative strip at the bottom of the top bar (acts as a shelf/border) -->
                <Rectangle VerticalAlignment="Bottom" Height="80" Fill="#E67E22" Stroke="#D35400" StrokeThickness="4" />

                <!-- HUD inner layout: two columns -->
                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <!-- Left: Customer speech bubble -->
                        <ColumnDefinition Width="350" />
                        <!-- Right: Earnings panel -->
                    </Grid.ColumnDefinitions>

                    <!--
                         CUSTOMER ORDER SPEECH BUBBLE (left side of HUD)
                         Shows which toppings the customer wants on their pizza
                     -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="30"
                            Width="400" Height="220"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="50,20,0,0"
                            BorderBrush="#BDC3C7" BorderThickness="4">
                        <Border.Effect>
                            <!-- Subtle drop shadow to lift the bubble off the background -->
                            <DropShadowEffect Color="#7F8C8D" BlurRadius="10" ShadowDepth="5" Opacity="0.5"/>
                        </Border.Effect>

                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <!-- Label -->
                            <TextBlock Text="🗣️ CUSTOMER:" FontSize="22" FontWeight="Bold" Foreground="#2980B9" />
                            <!-- Intro text -->
                            <TextBlock Text="I would like a pizza with:" FontSize="18" Foreground="#34495E" Margin="0,5,0,10"/>
                            <!-- Requested toppings — update these dynamically at runtime -->
                            <TextBlock Text="🍅 Tomato Sauce" FontSize="20" FontWeight="Bold" Foreground="#C0392B" Margin="0,2,0,0"/>
                            <TextBlock Text="🧀 Mozzarella"   FontSize="20" FontWeight="Bold" Foreground="#F1C40F" Margin="0,2,0,0"/>
                            <TextBlock Text="🥩 Kebab"    FontSize="20" FontWeight="Bold" Foreground="Brown" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Speech bubble tail — small triangle pointing down toward the customer area -->
                    <Polygon Grid.Column="0"
                             Points="0,0 30,40 60,0"
                             Fill="White"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="150,238,0,0" />

                    <!-- EARNINGS PANEL (right side of HUD) Displays current money earned — bind Text to a ViewModel -->
                    <Border Grid.Column="1"
                            Background="#2C3E50"
                            CornerRadius="15"
                            BorderBrush="#1ABC9C" BorderThickness="5"
                            Padding="20"
                            Height="150" VerticalAlignment="Top"
                            Margin="0,20,20,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="💰 EARNINGS" FontSize="20" FontWeight="Bold" Foreground="#1ABC9C" HorizontalAlignment="Center"/>
                            <!-- Earnings value — replace static text with a binding -->
                            <TextBlock Text="$ 0.00" FontSize="42" FontWeight="Bold" Foreground="#2ECC71" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
            <!-- END ROW 0 — TOP HUD BAR -->

            <!--
                 ROW 1 — MAIN GAMEPLAY AREA
                 Split into three columns:
                   Col 0 (400px) = Topping ingredient buttons + Undo
                   Col 1 (*)     = Pizza canvas + label
                   Col 2 (450px) = Oven + Bake button
            -->
            <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <!-- Col 0: Ingredient buttons -->
                        <ColumnDefinition Width="*" />
                        <!-- Col 1: Pizza canvas -->
                        <ColumnDefinition Width="450" />
                        <!-- Col 2: Oven panel -->
                    </Grid.ColumnDefinitions>

                    <!--
                         COLUMN 0 — INGREDIENT BUTTONS
                         Circular buttons for each available topping.
                         Connect Click handlers in code-behind to add toppings.
                    -->
                    <WrapPanel Grid.Column="0"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="20">

                        <!-- Kebab button -->
                        <Button x:Name="KebabButton" Width="130" Height="130" Margin="15"
                                Background="Brown" BorderBrush="#873600" BorderThickness="4"
                                Cursor="Hand" Click="Kebab_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <!-- Circular shape using Ellipse -->
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Kebab" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Mozzarella button -->
                        <Button x:Name="MozzaButton" Width="130" Height="130" Margin="15"
                                Background="AntiqueWhite" BorderBrush="#B7950B" BorderThickness="4"
                                Cursor="Hand" Click="Mozza_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Mozzarella" FontSize="22" FontWeight="Bold" Foreground="#7D6608" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Parma (Parma ham) button -->
                        <Button x:Name="ParmaButton" Width="130" Height="130" Margin="15"
                                Background="#E74C3C" BorderBrush="#943126" BorderThickness="4"
                                Cursor="Hand" Click="Parma_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Parma" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Gorgonzola button (label abbreviated to fit circle) -->
                        <Button x:Name="GorgonButton" Width="130" Height="130" Margin="15"
                                Background="#5DADE2" BorderBrush="#2874A6" BorderThickness="4"
                                Cursor="Hand" Click="Gorgon_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                        <TextBlock Text="Gorgonzolla." FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                   
                    </WrapPanel>
                    <!-- END COLUMN 0 — INGREDIENT BUTTONS -->

                    <!--
                         COLUMN 1 — PIZZA CANVAS
                         Visual representation of the pizza being assembled.
                         The two Ellipses form the crust (outer) and dough (inner).
                         Toppings should be layered on top of these at runtime.
                     -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <!-- Pizza visual container (500x500) -->
                        <Grid Width="500" Height="500">
                            <!-- Outer crust ring — dark orange border -->
                            <Ellipse Fill="#E67E22" Stroke="#BA4A00" StrokeThickness="10" />
                            <!-- Inner dough surface — lighter peach colour -->
                            <Ellipse Width="420" Height="420" Fill="#F5CBA7" Stroke="#E59866" StrokeThickness="8" />
                            <!-- Toppings will be added here dynamically at runtime -->
                        </Grid>

                        <!-- Pizza status label — update via binding to show current toppings list -->
                        <TextBlock Text="Your Pizza: Empty"
                                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"/>

                    </StackPanel>
                    <!-- END COLUMN 1 — PIZZA CANVAS -->

                    <!--
                         COLUMN 2 — OVEN PANEL
                         Decorative oven graphic + Bake Pizza action button.
                         The dark rounded Border mimics an oven mouth/door.
                     -->
                    <Border Grid.Column="2"
                            Background="#34495E"
                            CornerRadius="30"
                            Margin="20,40,40,40"
                            BorderBrush="#2C3E50" BorderThickness="10">
                        <StackPanel VerticalAlignment="Center" Margin="20">

                            <!-- Oven chamber — rounded top mimics the oven arch -->
                            <Border Background="#17202A"
                                    Height="250"
                                    CornerRadius="150,150,15,15"
                                    BorderBrush="#7F8C8D" BorderThickness="5"
                                    Margin="0,0,0,40">
                                <!-- Flame emoji decoration inside oven -->
                                <TextBlock Text="🔥 🔥 🔥" FontSize="48"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>
                            </Border>

                            <!-- Bake button — triggers pizza completion logic in code-behind -->
                            <Button Content="BAKE PIZZA"
                                    FontSize="32" FontWeight="Bold"
                                    Height="80"
                                    Background="#27AE60" Foreground="White"
                                    BorderThickness="4" BorderBrush="#1E8449"
                                    Cursor="Hand" />

                        </StackPanel>
                    </Border>
                    <!-- END COLUMN 2 — OVEN PANEL -->

                </Grid>
            </Border>
            <!-- END ROW 1 — MAIN GAMEPLAY AREA -->

        </Grid>
    </Viewbox>
</Window>
