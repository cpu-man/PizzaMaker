<Window x:Class="DesignPattern_Pizza.Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesignPattern_Pizza"
        mc:Ignorable="d"
    Title="Pizzeria Zygomatic Style" Height="1080" Width="1920"
        WindowStartupLocation="CenterScreen"
        Background="#A2D9CE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="350" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Rectangle VerticalAlignment="Bottom" Height="80" Fill="#E67E22" Stroke="#D35400" StrokeThickness="4" />

            <Grid Margin="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="350" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="30" Width="400" Height="220" 
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,20,0,0"
                        BorderBrush="#BDC3C7" BorderThickness="4">
                    <Border.Effect>
                        <DropShadowEffect Color="#7F8C8D" BlurRadius="10" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>

                    <StackPanel Margin="20" VerticalAlignment="Center">
                        <TextBlock Text="🗣️ KUNDE:" FontSize="22" FontWeight="Bold" Foreground="#2980B9" />
                        <TextBlock Text="Jeg vil gerne have en pizza med:" FontSize="18" Foreground="#34495E" Margin="0,5,0,10"/>
                        <TextBlock Text="🍅 Tomatsovs" FontSize="20" FontWeight="Bold" Foreground="#C0392B" Margin="0,2,0,0"/>
                        <TextBlock Text="🧀 Mozzarella" FontSize="20" FontWeight="Bold" Foreground="#F1C40F" Margin="0,2,0,0"/>
                        <TextBlock Text="🥩 Pepperoni" FontSize="20" FontWeight="Bold" Foreground="#8E44AD" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Polygon Grid.Column="0" Points="0,0 30,40 60,0" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,238,0,0" />

                <Border Grid.Column="1" Background="#2C3E50" CornerRadius="15" BorderBrush="#1ABC9C" BorderThickness="5" Padding="20"
                        Height="150" VerticalAlignment="Top" Margin="0,20,20,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="💰 INDTJENING" FontSize="20" FontWeight="Bold" Foreground="#1ABC9C" HorizontalAlignment="Center"/>
                        <TextBlock Text="$ 0.00" FontSize="42" FontWeight="Bold" Foreground="#2ECC71" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>


        <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="450" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <Button Width="130" Height="130" Margin="15" Background="#D35400" BorderBrush="#873600" BorderThickness="4" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                    <TextBlock Text="Kebab" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="130" Height="130" Margin="15" Background="#F1C40F" BorderBrush="#B7950B" BorderThickness="4" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                    <TextBlock Text="Ost" FontSize="22" FontWeight="Bold" Foreground="#7D6608" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="130" Height="130" Margin="15" Background="#E74C3C" BorderBrush="#943126" BorderThickness="4" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                    <TextBlock Text="Parma" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="130" Height="130" Margin="15" Background="#5DADE2" BorderBrush="#2874A6" BorderThickness="4" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="4"/>
                                    <TextBlock Text="Gorgonz." FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="130" Height="60" Margin="15,40,15,15" Background="#95A5A6" BorderBrush="#7F8C8D" BorderThickness="3" Cursor="Hand">
                        <TextBlock Text="↩ Fortryd" FontSize="18" FontWeight="Bold" Foreground="White" />
                    </Button>
                </WrapPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="500" Height="500">
                        <Ellipse Fill="#E67E22" Stroke="#BA4A00" StrokeThickness="10" />
                        <Ellipse Width="420" Height="420" Fill="#F5CBA7" Stroke="#E59866" StrokeThickness="8" />
                    </Grid>
                    <TextBlock Text="Din Pizza: Tom" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#34495E" CornerRadius="30" Margin="20,40,40,40" BorderBrush="#2C3E50" BorderThickness="10">
                    <StackPanel VerticalAlignment="Center" Margin="20">
                        <Border Background="#17202A" Height="250" CornerRadius="150,150,15,15" BorderBrush="#7F8C8D" BorderThickness="5" Margin="0,0,0,40">
                            <TextBlock Text="🔥 🔥 🔥" FontSize="48" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        </Border>

                        <Button Content="BAG PIZZA" FontSize="32" FontWeight="Bold" Height="80" 
                                Background="#27AE60" Foreground="White" BorderThickness="4" BorderBrush="#1E8449" Cursor="Hand" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>