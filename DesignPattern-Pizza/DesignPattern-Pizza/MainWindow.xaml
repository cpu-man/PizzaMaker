<Window x:Class="DesignPattern_Pizza.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesignPattern_Pizza"
        mc:Ignorable="d"
        Title="Pizzeria"
        Icon="/Pizza Maker.game.logo.ico"
        WindowState="Maximized"
        Background="#A2D9CE">

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">

            <!-- Title -->
            <TextBlock Text="🍕 Pizza Maker"
                       FontSize="120" FontWeight="Bold" Foreground="#E67E22"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,0,0,300"/>

            <!-- Buttons -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Orientation="Horizontal" Margin="0,200,0,0">

                <Button x:Name="Play" Content="PLAY"
                        Width="300" Height="100" Margin="30,0"
                        FontSize="40" FontWeight="Bold"
                        Background="#27AE60" Foreground="White"
                        BorderBrush="#1E8449" BorderThickness="4"
                        Cursor="Hand" Click="Play_Click"/>

                <Button x:Name="Instructions" Content="HOW TO PLAY"
                        Width="300" Height="100" Margin="30,0"
                        FontSize="40" FontWeight="Bold"
                        Background="#2980B9" Foreground="White"
                        BorderBrush="#1F618D" BorderThickness="4"
                        Cursor="Hand" Click="Instructions_Click"/>

            </StackPanel>

        </Grid>
    </Viewbox>

</Window>