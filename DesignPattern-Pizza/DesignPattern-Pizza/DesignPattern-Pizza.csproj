<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>DesignPattern_Pizza</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="images_png\Bianca base.png" />
    <None Remove="images_png\Gorgonzola Topping.png" />
    <None Remove="images_png\Kebab Topping.png" />
    <None Remove="images_png\Kebab_Topping.png" />
    <None Remove="images_png\Margarita base.png" />
    <None Remove="images_png\Mozzarella Topping.png" />
    <None Remove="images_png\Parma Topping.png" />
    <None Remove="images_png\StartSplash.png" />
    <None Remove="Sounds\balloon.mp3" />
    <None Remove="Sounds\Fire.mp3" />
    <None Remove="Sounds\Money.mp3" />
    <None Remove="Sounds\Wrong.mp3" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Sounds\balloon.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Sounds\Fire.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Sounds\Wrong.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="images_png\Bianca base.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="images_png\Gorgonzola Topping.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="images_png\Kebab_Topping.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="images_png\Margarita base.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="images_png\Mozzarella Topping.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="images_png\Parma Topping.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="images_png\StartSplash.png" />
    <Content Include="Sounds\Money.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
